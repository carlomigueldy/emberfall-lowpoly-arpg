{
  "name": "emberfall-lowpoly-arpg",
  "version": "0.1.0",
  "private": true,
  "description": "Emberfall: a stylized low-poly isometric action RPG inspired by dark fantasy dungeon crawlers, built with Three.js.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "three": "latest"
  },
  "devDependencies": {
    "@types/three": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
