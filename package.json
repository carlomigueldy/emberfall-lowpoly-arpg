{
  "name": "emberfall-lowpoly-arpg",
  "version": "0.1.0",
  "private": true,
  "description": "Emberfall: a stylized low-poly isometric browser ARPG with warm ember-lit dungeons, combat, loot, leveling, boss fight, and mobile controls.",
  "homepage": "https://emberfall-lowpoly-arpg.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlomigueldy/emberfall-lowpoly-arpg.git"
  },
  "bugs": {
    "url": "https://github.com/carlomigueldy/emberfall-lowpoly-arpg/issues"
  },
  "keywords": [
    "threejs",
    "vite",
    "typescript",
    "webgl",
    "game",
    "arpg",
    "low-poly",
    "browser-game"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "three": "latest"
  },
  "devDependencies": {
    "@types/three": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
